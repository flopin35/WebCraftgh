{
  "name": "nf",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/copy-spa-fallback.mjs",
    "preview": "vite preview",
    "test:security": "node scripts/security-check.mjs",
    "test:custom": "node scripts/custom-flow-test.mjs",
    "build:prod": "npm run test:security && node scripts/verify-build-env.mjs && npm run build",
    "deploy:rules": "firebase deploy --only firestore:rules,storage",
    "deploy": "npm run deploy:rules"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "firebase": "^12.14.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0"
  }
}
