rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /websiteRequests/{requestId} {
      allow create: if isValidWebsiteRequest();
      allow read: if isAdmin();
      allow update: if isAdmin() && isWebsiteRequestAdminUpdateOnly();
      allow delete: if false;
    }

    match /customWebsiteRequests/{requestId} {
      allow create: if isValidCustomWebsiteRequest();
      allow read: if isAdmin();
      allow update: if isAdmin() && isCustomWebsiteRequestAdminUpdateOnly();
      allow delete: if false;
    }
  }
}

function isAdmin() {
  return request.auth != null
    && request.auth.token.email == 'daakukwaku7@gmail.com';
}

function isValidTemplate(template) {
  return template.id is string
    && template.name is string
    && template.price is number
    && (
      (template.id == 'business' && template.name == 'Business Website' && template.price == 1200)
      || (template.id == 'store' && template.name == 'Store Website' && template.price == 1500)
      || (template.id == 'political' && template.name == 'Political/Foundation Website' && template.price == 1100)
      || (template.id == 'business-starter' && template.name == 'Business Starter' && template.price == 1200)
      || (template.id == 'business-pro' && template.name == 'Business Pro' && template.price == 1800)
      || (template.id == 'school-starter' && template.name == 'School Basic' && template.price == 1100)
      || (template.id == 'school-pro' && template.name == 'School Pro' && template.price == 1500)
      || (template.id == 'foundation-starter' && template.name == 'Foundation Basic' && template.price == 1100)
      || (template.id == 'foundation-pro' && template.name == 'Foundation Pro' && template.price == 1400)
      || (template.id == 'church-starter' && template.name == 'Church Basic' && template.price == 1100)
      || (template.id == 'church-pro' && template.name == 'Church Pro' && template.price == 1400)
      || (template.id == 'portfolio-starter' && template.name == 'Portfolio Basic' && template.price == 900)
      || (template.id == 'portfolio-pro' && template.name == 'Portfolio Pro' && template.price == 1200)
      || (template.id == 'political-starter' && template.name == 'Campaign Basic' && template.price == 1100)
      || (template.id == 'political-pro' && template.name == 'Campaign Pro' && template.price == 1500)
    );
}

function isValidLeadSummary(leadSummary) {
  return leadSummary is map
    && leadSummary.name is string
    && leadSummary.name.size() > 0
    && leadSummary.businessName is string
    && leadSummary.businessName.size() > 0
    && leadSummary.businessType is string
    && leadSummary.businessType.size() > 0
    && leadSummary.websiteGoal is string
    && leadSummary.websiteGoal.size() > 0
    && leadSummary.budget is string
    && leadSummary.budget.size() > 0
    && leadSummary.timeline is string
    && leadSummary.timeline.size() > 0
    && leadSummary.selectedFeatures is list
    && leadSummary.estimatedValue is number
    && leadSummary.estimatedValue >= 0
    && leadSummary.leadScore is number
    && leadSummary.leadScore >= 1
    && leadSummary.leadScore <= 100;
}

function isValidWebsiteRequest() {
  let data = request.resource.data;
  let expectedDeploymentFee = data.deployment ? 600 : 0;

  return data.receiptId is string
    && data.receiptId.matches('REQ-[0-9]{6}')
    && data.status == 'Pending Review'
    && data.customer.fullName is string
    && data.customer.fullName.size() > 0
    && data.customer.fullName.size() <= 120
    && data.customer.phone is string
    && data.customer.phone.size() > 0
    && data.customer.phone.size() <= 30
    && data.customer.businessName is string
    && data.customer.businessName.size() > 0
    && data.customer.businessName.size() <= 120
    && data.customer.email is string
    && data.customer.email.size() <= 120
    && isValidTemplate(data.template)
    && data.deployment is bool
    && data.selectedFeatures is list
    && data.selectedUpgrades is list
    && data.selectedFeatures.size() <= 20
    && data.selectedUpgrades.size() <= 20
    && data.totalPrice is number
    && data.totalPrice >= data.template.price
    && data.totalPrice <= 50000
    && data.pricing is map
    && data.pricing.total is number
    && data.pricing.total == data.totalPrice
    && data.pricing.templatePrice == data.template.price
    && data.pricing.upgradesSubtotal is number
    && data.pricing.upgradesSubtotal >= 0
    && data.pricing.bundleDiscount is number
    && data.pricing.bundleDiscount >= 0
    && data.pricing.deploymentFee is number
    && data.pricing.deploymentFee == expectedDeploymentFee
    && data.totalPrice
      == data.pricing.templatePrice
        + data.pricing.upgradesSubtotal
        + data.pricing.deploymentFee
    && data.notes is string
    && data.notes.size() <= 2000
    && data.adminNotes == ''
    && data.requestProgress == ''
    && data.websiteTypeId is string
    && data.websiteTypeId.size() > 0
    && data.leadSummary is map
    && isValidLeadSummary(data.leadSummary);
}

function isWebsiteRequestAdminUpdateOnly() {
  let incoming = request.resource.data;
  let existing = resource.data;

  return incoming.receiptId == existing.receiptId
    && incoming.customer == existing.customer
    && incoming.template == existing.template
    && incoming.selectedFeatures == existing.selectedFeatures
    && incoming.selectedUpgrades == existing.selectedUpgrades
    && incoming.selectedBundle == existing.selectedBundle
    && incoming.pricing == existing.pricing
    && incoming.deployment == existing.deployment
    && incoming.totalPrice == existing.totalPrice
    && incoming.notes == existing.notes
    && incoming.leadSummary == existing.leadSummary
    && incoming.websiteTypeId == existing.websiteTypeId
    && incoming.createdAt == existing.createdAt
    && incoming.status is string
    && incoming.adminNotes is string
    && incoming.adminNotes.size() <= 5000
    && incoming.requestProgress is string
    && incoming.requestProgress.size() <= 5000;
}

function isValidCustomWebsiteRequest() {
  let data = request.resource.data;

  return data.receiptId is string
    && data.receiptId.matches('CW-[0-9]{6}')
    && data.status == 'Pending Review'
    && data.customer.fullName is string
    && data.customer.fullName.size() > 0
    && data.customer.fullName.size() <= 120
    && data.customer.phone is string
    && data.customer.phone.size() > 0
    && data.customer.phone.size() <= 30
    && data.customer.email is string
    && data.customer.email.size() > 0
    && data.customer.email.size() <= 120
    && data.customer.businessName is string
    && data.customer.businessName.size() > 0
    && data.customer.businessName.size() <= 120
    && data.customer.businessType is string
    && data.customer.businessType.size() > 0
    && data.websiteGoals is list
    && data.websiteGoals.size() > 0
    && data.websiteGoals.size() <= 10
    && data.selectedFeatures is list
    && data.selectedFeatures.size() <= 20
    && data.projectDetails is map
    && data.projectDetails.description is string
    && data.projectDetails.description.size() > 0
    && data.projectDetails.description.size() <= 5000
    && data.budget is string
    && data.budget.size() > 0
    && data.timeline is string
    && data.timeline.size() > 0
    && data.uploadedFiles is list
    && data.uploadedFiles.size() <= 9
    && data.uploadWarnings is list
    && data.estimatedPriceRange is string
    && data.estimatedPriceRange.size() > 0
    && data.estimatedPriceRange.size() <= 40
    && data.leadSummary is map
    && isValidLeadSummary(data.leadSummary)
    && data.adminNotes == ''
    && data.requestProgress == '';
}

function isCustomWebsiteRequestAdminUpdateOnly() {
  let incoming = request.resource.data;
  let existing = resource.data;

  return incoming.receiptId == existing.receiptId
    && incoming.customer == existing.customer
    && incoming.websiteGoals == existing.websiteGoals
    && incoming.selectedFeatures == existing.selectedFeatures
    && incoming.projectDetails == existing.projectDetails
    && incoming.budget == existing.budget
    && incoming.timeline == existing.timeline
    && incoming.uploadedFiles == existing.uploadedFiles
    && incoming.uploadWarnings == existing.uploadWarnings
    && incoming.estimatedPriceRange == existing.estimatedPriceRange
    && incoming.leadSummary == existing.leadSummary
    && incoming.createdAt == existing.createdAt
    && incoming.status is string
    && incoming.adminNotes is string
    && incoming.adminNotes.size() <= 5000
    && incoming.requestProgress is string
    && incoming.requestProgress.size() <= 5000;
}
