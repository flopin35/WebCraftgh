rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /websiteRequests/{requestId} {
      allow create: if isValidWebsiteRequest();
      allow read: if isAdmin();
      allow update: if isAdmin() && isAdminUpdateOnly();
      allow delete: if false;
    }
  }
}

function isAdmin() {
  return request.auth != null
    && request.auth.token.email == 'daakukwaku7@gmail.com';
}

function isValidTemplate(template) {
  return template.id is string
    && template.name is string
    && template.price is number
    && (
      (template.id == 'business' && template.name == 'Business Website' && template.price == 1200)
      || (template.id == 'store' && template.name == 'Store Website' && template.price == 1500)
      || (template.id == 'political' && template.name == 'Political/Foundation Website' && template.price == 1100)
    );
}

function isValidWebsiteRequest() {
  let data = request.resource.data;
  let expectedDeploymentFee = data.deployment ? 600 : 0;

  return data.receiptId is string
    && data.receiptId.matches('REQ-[0-9]{6}')
    && data.status == 'Pending Review'
    && data.customer.fullName is string
    && data.customer.fullName.size() > 0
    && data.customer.fullName.size() <= 120
    && data.customer.phone is string
    && data.customer.phone.size() > 0
    && data.customer.phone.size() <= 30
    && data.customer.businessName is string
    && data.customer.businessName.size() > 0
    && data.customer.businessName.size() <= 120
    && data.customer.email is string
    && data.customer.email.size() <= 120
    && isValidTemplate(data.template)
    && data.deployment is bool
    && data.selectedFeatures is list
    && data.selectedUpgrades is list
    && data.selectedFeatures.size() <= 20
    && data.selectedUpgrades.size() <= 20
    && data.totalPrice is number
    && data.totalPrice >= data.template.price
    && data.totalPrice <= 50000
    && data.pricing is map
    && data.pricing.total is number
    && data.pricing.total == data.totalPrice
    && data.pricing.templatePrice == data.template.price
    && data.pricing.upgradesSubtotal is number
    && data.pricing.upgradesSubtotal >= 0
    && data.pricing.bundleDiscount is number
    && data.pricing.bundleDiscount >= 0
    && data.pricing.deploymentFee is number
    && data.pricing.deploymentFee == expectedDeploymentFee
    && data.totalPrice
      == data.pricing.templatePrice
        + data.pricing.upgradesSubtotal
        + data.pricing.deploymentFee
    && data.notes is string
    && data.notes.size() <= 2000
    && data.adminNotes == ''
    && data.requestProgress == '';
}

function isAdminUpdateOnly() {
  let incoming = request.resource.data;
  let existing = resource.data;

  return incoming.receiptId == existing.receiptId
    && incoming.customer == existing.customer
    && incoming.template == existing.template
    && incoming.selectedFeatures == existing.selectedFeatures
    && incoming.selectedUpgrades == existing.selectedUpgrades
    && incoming.selectedBundle == existing.selectedBundle
    && incoming.pricing == existing.pricing
    && incoming.deployment == existing.deployment
    && incoming.totalPrice == existing.totalPrice
    && incoming.notes == existing.notes
    && incoming.createdAt == existing.createdAt
    && incoming.status is string
    && incoming.adminNotes is string
    && incoming.adminNotes.size() <= 5000
    && incoming.requestProgress is string
    && incoming.requestProgress.size() <= 5000;
}
